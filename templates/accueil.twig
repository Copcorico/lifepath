<!DOCTYPE html>
<html lang="fr">

<head>
<meta charset="UTF-8">
    <title>LifePath</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="icon" type="image/png" href="/images/logos/personnagesansfondombre.png">
</head>

<body>
{# Navbar #}
{% include 'style_base/_navbar.twig' %}
{# Header #}
{% include 'style_base/_header.twig' %}
<section>
    <!-- A propos -->
    <article class="apropos-container">
        <div class="forme-apropos">
            <h2 class="apropos-title" id="apropos">À propos</h2>
            <p class="apropos-text">Si votre objectif est d'en apprendre davantage sur nos services et notre mission, ou tout autre point au sujet de notre entreprise, vous êtes au bon endroit.
            Alors n'hésitez pas à explorer notre page à propos afin d'apprendre ce que vous pourriez ignorez à notre sujet !</p>
            <button class="apropos-bouton" type="button" onclick="window.location.href='/a_propos'">-&gt;</button>
        </div>
    </article>

    <!-- Offers -->
    <h2 class="offers-header" id="offres">Offres</h2>

    <div class="offre-global-container">
            {% for offre in offers %}
				<article class="offre-container">
                    {% for profile in profiles %}
                        {% if profile.id_profil == offre.id_profil %}
                            <a
                            href="/offre?id={{ offre.id_offre|default(0) }}"
                            aria-label="Voir l'annonce de {{ offre.entreprise|default('cette entreprise') }}"
                            >
                            <div class="offre-profile">
                                <img src="/images/profils/{{ profile.photo|default('profile.png') }}" alt="Photo de profil de {{ profile.prenom|default('l\'utilisateur') }}" class="offre-profile-img">
                                <h2> {{ offre.titre|default(offre.intitule|default('Offre de stage')) }} </h2>
                                <ul class="offre-ul">
                                    <li class="offres-li">Poste : {{ offre.poste|default('Non précisé') }} </li>
                                    <li class="offres-li">Entreprise : {{ offre.entreprise|default('Non précisée') }} </li>
                                    <li class="offres-li">Lieu : {{ offre.lieu|default(offre.localisation|default('Non précisé')) }} </li>
                                    <li class="offres-li">Niveau : {{ offre.niveau|default('Non précisé') }}</li>
                                </ul>
                                <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Reiciendis inventore excepturi corrupti hic, harum perferendis</p>
                                <a href="/entreprise?id={{ offre.id_entreprise|default(0) }}" class="btn-postuler">Voir la fiche entreprise</a>
                            </div>
                            </a>
                        {% else %}
                            <a
                            href="/offre?id={{ offre.id_offre|default(0) }}"
                            aria-label="Voir l'annonce de {{ offre.entreprise|default('cette entreprise') }}"
                            >
                            <div class="offre-profile">
                                <img src="/images/profils/toutou_travailleur.png" alt="Photo de profil par défaut" class="offre-profile-img">
                                <h2> {{ offre.titre|default(offre.intitule|default('Offre de stage')) }} </h2>
                                <ul class="offre-ul">
                                    <li class="offres-li">Poste : {{ offre.poste|default('Non précisé') }} </li>
                                    <li class="offres-li">Entreprise : {{ offre.entreprise|default('Non précisée') }} </li>
                                    <li class="offres-li">Lieu : {{ offre.lieu|default(offre.localisation|default('Non précisé')) }} </li>
                                    <li class="offres-li">Niveau : {{ offre.niveau|default('Non précisé') }}</li>
                                </ul>
                                <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Reiciendis inventore excepturi corrupti hic, harum perferendis</p>
                                <a href="/entreprise?id={{ offre.id_entreprise|default(0) }}" class="btn-postuler">Voir la fiche entreprise</a>
                            </div>
                            </a>
                        {% endif %}
                    {% endfor %}
                </article>
			{% else %}
				<p>Aucune offre disponible pour le moment.</p>
			{% endfor %}
    </div>
    <!-- Comptes -->
    <h2 class="compte-title" id="compte">Comptes</h2>
    <section class="comptes-carousel">
            <div class="carousel-compte">
            {% for profile in profiles|slice(0, 16) %}
                {% for particulier in particuliers %}
                    {% if profile.id_profile == particulier.id_profil %}
                    <div class="comtes-item">
                        <div class="compte-label"><img  class="nav-profile-icon" src={{ profile.getPhoto()|default('/images/profils/profile.png') }} alt="logo lifePath"> {{ particulier.prenom|default('l\'utilisateur') }}</div>
                    </div>
                    {% endif %}
                {% endfor %}
            {% endfor %}
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/Davy.jpg" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/Noah.jpg" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/Titouan.jpg" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/Maëlyne.jpg" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
                <div class="compte-item">
                    <div class="compte-label"><img  class="nav-profile-icon" src="images/profils/profile.png" alt="logo lifePath"> jean jeans</div>
                </div>
            </div>
    </section>
    <!-- Entreprise -->
    <h2 class="entreprise-title" >Entreprise</h2>
    <section class="entreprise-carousel">
            <div class="carousel-entreprise">
                {% for company in companies|slice(0, 10) %}
                    {% if company.id_entreprise is not empty %}
                        <a
                            class="entreprise-link"
                            href="/entreprise?id={{ company.id_entreprise }}"
                            aria-label="Voir l'annonce de {{ company.nom|default('cette entreprise') }}"
                        >
                            <article class="entreprise-item">
                                <h3>{{ company.nom|default('Entreprise') }}</h3>
                                <section class="entreprise-section">
                                    <div class="star-rating">
                                        {% for i in 1..5 %}
                                        {% if i <= company.note %}★{% else %}☆{% endif %}
                                        {% endfor %}
                                    <span>({{ company.note }}/5)</span>
                                    </div>
                                <p>
                                    {{ company.description|default('Aucune description disponible.') }}
                                </p>
                                <div class="company-meta">
                                    <span><strong>Lieu:</strong> {{ company.adresse|default('Non renseigne') }}</span>
                                </div>
                                </section>
                            </article>
                        </a>
                    {% endif %}
                {% else %}
                    <p>Aucune entreprise disponible pour le moment.</p>
                {% endfor %}
            </div>
    </section>
</section>
{% include 'style_base/_footer.twig' %}
<script src="/script.js"></script>

</body>
</html>