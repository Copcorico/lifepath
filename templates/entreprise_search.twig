<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0">-->
    <title>Entreprise - LifePath</title>
    <link rel="stylesheet" href="assets/style.css">
    <link rel="icon" type="image/png" href="images/logos/personnagesansfondombre.png">
</head>

<body>
    <!-- Overlay -->
    <div class="overlay" id="overlay"></div>

    <!-- Navbar -->
    <nav class="navbar" id="navbar">
        <div class="hamburger" onclick="toggleNav()">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="profile-section">
            <div class="profile-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="8" r="4" fill="#1e3a5f"/>
                    <path d="M4 20c0-4 3.5-7 8-7s8 3 8 7" stroke="#1e3a5f" stroke-width="2" fill="none"/>
                </svg>
            </div>
            <div class="profile-info">
                <h2>NOM COMPLET</h2>
                <p>NOM pilote</p>
            </div>
        </div>

        <div class="divider"></div>

        <ul class="menu">
            <li class="menu-item active">
                <a href="index.html">
                    <div class="home-icon"></div>
                    Accueil
                    <span class="arrow">∨</span>
                </a>
                <ul class="submenu">
                    <li><a href="#offres">Offres</a></li>
                    <li><a href="#">Entreprises</a></li>
                    <li><a href="#">Comptes</a></li>
                </ul>
                <a href="inscription_entreprise.html">
                    Inscription
                </a>
                <a href="inscription_particulier.html">
                    Inscription
                </a>
                <a href="connexion.html">
                    Connexion
                </a>
                <a href="offres.html">
                    Nos offres
                </a>
                <a href="entreprise.html">
                    Entreprise
                </a>
                <a href="avis.html">
                    Avis
                </a>
                <a href="legale.html">
                    Mentions légales
                </a>
            </li>
        </ul>
    </nav>

    <div class="main-content">
        <!-- Header -->
        <header class="header">
            <div class="header-hamburger" onclick="toggleNav()">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <h1>LifePath</h1>
            <img src="images/logos/personnagesansfondombre.png" alt="logo lifePath" class="header-icon">
        </header>
    </div>

    <main>
        <article class="entreprise-container">
            <section class="entreprise-section">
                <h1>Recherche d'entreprises</h1>
                <p>Trouvez une entreprise par son nom.</p>
            </section>

            <section id="entreprises">
                <form method="get" action="/entreprise" class="search-form" style="display:flex; gap:12px; margin: 20px 0; flex-wrap: wrap;">
                    <input
                        type="text"
                        name="q"
                        value="{{ query|default('') }}"
                        placeholder="Ex: Tech, Digital, CESI..."
                        aria-label="Rechercher une entreprise par nom"
                        style="flex:1; min-width: 240px; padding: 10px 14px; border: 1px solid #d0d6dd; border-radius: 10px;"
                    >
                    <button type="submit" style="padding: 10px 18px; border: 0; border-radius: 10px; background: #1e3a5f; color: #fff; cursor: pointer;">Rechercher</button>
                </form>

                {% if query is not empty %}
                    <p><strong>{{ companies|length }}</strong> resultat(s) pour "{{ query }}".</p>
                {% endif %}

                <div class="companies-results" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 16px;">
                    {% for company in companies %}
                        <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px; box-shadow:0 4px 14px rgba(0, 0, 0, 0.06);">
                            <h3 style="margin:0 0 8px 0;">{{ company.nom|default('Entreprise') }}</h3>
                            <p style="margin:0 0 10px 0; color:#4b5563;">
                                {{ company.description|default('Aucune description disponible.') }}
                            </p>
                            <div style="font-size: 14px; color:#374151;">
                                <span><strong>Employes:</strong> {{ company.nombre_employes|default('Non renseigne') }}</span>
                            </div>
                        </article>
                    {% else %}
                        <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px;">
                            <h3 style="margin:0 0 8px 0;">Aucune entreprise trouvee</h3>
                            <p style="margin:0; color:#4b5563;">Essayez un autre nom ou une recherche plus courte.</p>
                        </article>
                    {% endfor %}
                </div>
            </section>
        </article>
    </main>

    <footer>
        <p>&copy; 2026 Tous droits réservés</p>
        <a href="legale.html">Mentions légales et politique de confidentialité</a>
    </footer>


</body>
</html>
