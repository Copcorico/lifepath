<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0">-->
    <title>Entreprise - LifePath</title>
    <link rel="stylesheet" href="assets/style.css">
    <link rel="icon" type="image/png" href="images/logos/personnagesansfondombre.png">
</head>

<body>

{% include 'style_base/_navbar.twig' %}
{% include 'style_base/_header.twig' %}

    <main class="offer-detail">
        <article class="entreprise-container">
            <section class="entreprise-section">
                <h1>Recherche d'entreprises</h1>
                <p>Trouvez une entreprise par son nom.</p>
            </section>

            <section id="entreprises">
                <form method="get" action="/entreprise" class="search-form" style="display:flex; gap:12px; margin: 20px 0; flex-wrap: wrap;">
                    {% if note_min is not null %}
                        <input type="hidden" name="note_min" value="{{ note_min }}">
                    {% endif %}
                    {% if note_max is not null %}
                        <input type="hidden" name="note_max" value="{{ note_max }}">
                    {% endif %}
                    <input
                        type="text"
                        name="q"
                        value="{{ query|default('') }}"
                        placeholder="Ex: Tech, Digital, CESI..."
                        aria-label="Rechercher une entreprise par nom"
                        style="flex:1; min-width: 240px; padding: 10px 14px; border: 1px solid #d0d6dd; border-radius: 10px;"
                    >
                    <button type="submit" class="search-button">Rechercher</button>
                </form>
                <button
                    type="button"
                    class="search-button"
                    style="display:inline-flex; align-items:center; gap:8px;"
                    aria-expanded="false"
                    aria-controls="filters-panel"
                    onclick="(function(){const p=document.getElementById('filters-panel');const open=p.style.display==='block';p.style.display=open?'none':'block';this.setAttribute('aria-expanded', open ? 'false' : 'true');}).call(this)();"
                >
                    Filtres
                    <img src="/images/logos/filter.png" alt="logo filtres">
                </button>

                <section
                    id="filters-panel"
                    style="display:{% if note_min is not null or note_max is not null %}block{% else %}none{% endif %}; margin-top:12px; background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px; max-width:500px;"
                >
                    <form method="get" action="/entreprise" style="display:grid; gap:10px;">
                        {% if query is not empty %}
                            <input type="hidden" name="q" value="{{ query }}">
                        {% endif %}

                        <label for="note_min">Note minimale</label>
                        <input
                            id="note_min"
                            type="number"
                            name="note_min"
                            min="0"
                            max="5"
                            step="0.1"
                            value="{{ note_min is not null ? note_min : '' }}"
                            placeholder="Ex: 2.5"
                            style="padding: 10px 14px; border: 1px solid #d0d6dd; border-radius: 10px;"
                        >

                        <label for="note_max">Note maximale</label>
                        <input
                            id="note_max"
                            type="number"
                            name="note_max"
                            min="0"
                            max="5"
                            step="0.1"
                            value="{{ note_max is not null ? note_max : '' }}"
                            placeholder="Ex: 4.5"
                            style="padding: 10px 14px; border: 1px solid #d0d6dd; border-radius: 10px;"
                        >

                        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:6px;">
                            <button type="submit" class="search-button">Appliquer</button>
                            <a href="/entreprise{% if query is not empty %}?q={{ query|url_encode }}{% endif %}" class="search-button" style="text-decoration:none; display:inline-flex; align-items:center;">Reinitialiser</a>
                        </div>
                    </form>
                </section>
                {% if query is not empty %}
                    <p><strong>{{ companies|length }}</strong> resultat(s) pour "{{ query }}".</p>
                {% endif %}

                {% if note_min is not null or note_max is not null %}
                    <p>
                        Filtres actifs:
                        note
                        {% if note_min is not null %}
                            min {{ note_min }}
                        {% endif %}
                        {% if note_max is not null %}
                            max {{ note_max }}
                        {% endif %}
                    </p>
                {% endif %}

                <div class="companies-results" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 16px;">
                    {% for company in companies %}
                        <a
                            href="/entreprise?id={{ company.id_entreprise }}"
                            style="display:block; text-decoration:none; color:inherit;"
                            aria-label="Voir l'annonce de {{ company.nom|default('cette entreprise') }}"
                        >
                            <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px; box-shadow:0 4px 14px rgba(0, 0, 0, 0.06); transition: transform .15s ease, box-shadow .15s ease;">
                                <h3 style="margin:0 0 8px 0;">{{ company.nom|default('Entreprise') }}</h3>
                                <section class="entreprise-section">
                                    <div class="star-rating">
                                        {% for i in 1..5 %}
                                        {% if i <= company.note %}★{% else %}☆{% endif %}
                                        {% endfor %}
                                    <span>({{ company.note }}/5)</span>
                                    </div>
            </section>
                                <p style="margin:0 0 10px 0; color:#4b5563;">
                                    {{ company.description|default('Aucune description disponible.') }}
                                </p>
                                <div style="font-size: 14px; color:#374151;">
                                    <span><strong>Employes:</strong> {{ company.nombre_employes|default('Non renseigne') }}</span>
                                </div>
                            </article>
                        </a>
                    {% else %}
                        <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px;">
                            <h3 style="margin:0 0 8px 0;">Aucune entreprise trouvee</h3>
                            <p style="margin:0; color:#4b5563;">Essayez un autre nom ou une recherche plus courte.</p>
                        </article>
                    {% endfor %}
                </div>
            </section>
        </article>
    </main>

    <footer>
        <p>&copy; 2026 Tous droits réservés</p>
        <a href="legale.html">Mentions légales et politique de confidentialité</a>
    </footer>


</body>
</html>
