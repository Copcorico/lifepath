<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>LifePath - Mon Profil</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="icon" type="image/png" href="/images/logos/personnagesansfondombre.png">
</head>

<body>
{% include 'style_base/_navbar.twig' %}
{% include 'style_base/_header.twig' %}

<main>
    <section class="profil-section">
        <h1>Mon Profil</h1>
        
        {% if app.session.has('user_id') %}
            <div class="profil-info">
                {% if app.session.has('profil_error') %}
                    <p class="profil-error">{{ app.session.get('profil_error') }}</p>
                {% endif %}

                <div class="profil-photo-block">
                    <div class="profil-photo-wrapper">
                        <img
                            src="/images/profils/{{ app.session.get('photo', 'profile.png') }}"
                            alt="Photo de profil"
                            class="profil-photo"
                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                        >
                        <span class="profil-photo-fallback">Image indisponible</span>
                    </div>

                    <form method="POST" action="/profil/photo" enctype="multipart/form-data" class="profil-photo-form">
                        <input type="file" id="photo" name="photo" accept="image/png,image/jpeg,image/webp" hidden>
                        <label for="photo" class="profil-photo-btn">Choisir une image</label>
                        <button type="submit" class="profil-photo-submit">Modifier l'image</button>
                    </form>
                </div>

                {% if app.session.get('type') == 'etudiant' or app.session.get('type') == 'pilote' %}
                    <form method="POST" action="/profil/update">
                        <h2>Informations Personnelles</h2>

                        <label>Prénom :</label>
                        <input type="text" name="prenom" value="{{ app.session.get('prenom') }}">

                        <label>Nom :</label>
                        <input type="text" name="nom" value="{{ app.session.get('nom') }}">

                        <label>Email :</label>
                        <input type="email" name="email" value="{{ app.session.get('email') }}">

                        <button type="submit">Enregistrer</button>
                    </form>
                {% else %}
                    <form method="POST" action="/profil/update">
                        <h2>Informations Entreprise</h2>

                        <label>Société :</label>
                        <input type="text" name="societe" value="{{ app.session.get('societe') }}">

                        <label>Email :</label>
                        <input type="email" name="email" value="{{ app.session.get('email') }}">

                        <label>Adresse :</label>
                        <input type="text" name="adresse" value="{{ app.session.get('adresse') }}">

                        <label>Description :</label>
                        <textarea name="description">{{ app.session.get('description') }}</textarea>

                        <button type="submit">Enregistrer</button>
                    </form>
                {% endif %}
            </div>
        {% else %}
            <div class="profil-not-log-in">
                <p>Vous n'êtes pas connecté.</p>
                <p><a href="/connexion" style="color: #0066cc; text-decoration: underline;">Se connecter</a></p>
            </div>
        {% endif %}
    </section>
</main>

<script src="/script.js"></script>
</body>

</html>
