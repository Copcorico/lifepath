<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>LifePath - Mon Profil</title>
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="icon" type="image/png" href="/images/logos/personnagesansfondombre.png">
</head>

<body>
<!-- Overlay -->
<div class="overlay" id="overlay"></div>

<!-- Navbar -->
<nav class="navbar" id="navbar">
    <div class="hamburger" onclick="toggleNav()">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div class="nav-profile-section">
        <img  class="nav-profile-icon" src="/images/profils/profile.png" alt="logo lifePath">
        <div class="nav-profile-info">
            {% if app.session.has('user_id') %}
                <h2>
                    {% if app.session.get('type') == 'particulier' %}
                        {{ app.session.get('prenom') }} {{ app.session.get('nom') }}
                    {% else %}
                        {{ app.session.get('societe') }}
                    {% endif %}
                </h2>
                {% if app.session.get('type') == 'particulier' %}
                    <p class="navbar-pilote">Particulier</p>
                {% else %}
                    <p class="navbar-pilote">Entreprise</p>
                {% endif %}
            {% else %}
                <h2><a href="/profil">NOM COMPLET</a></h2>
                <p class="navbar-pilote">Non connecté</p>
            {% endif %}
        </div>
    </div>

    <div class="divider"></div>

    <ul class="nav-menu">
        <li class="nav-menu-item">
            <div class="row" onclick="toggleRow(this)">
                <div class="nav-container-menu">
                    <a href="/">Accueil </a>
                    <div class="arrow">></div>
                </div>
                <ul class="nav-submenu">
                    <li><a href="/#offres">Offres</a></li>
                    <li><a href="/#apropos">Entreprises</a></li>
                    <li><a href="/#compte">Comptes</a></li>
                </ul>
            </div>
        </li>
        {% if not app.session.has('user_id') %}
        <li class="nav-menu-item"><a href="/inscription">Inscription</a></li>
        <li class="nav-menu-item"><a href="/connexion">Connexion</a></li>
        {% endif %}
        <li class="nav-menu-item"><a href="/offres">Nos offres</a></li>
        <li class="nav-menu-item"><a href="/entreprise">Entreprise</a></li>
        <li class="nav-menu-item"><a href="/avis">Avis</a></li>
        <li class="nav-menu-item"><a href="/legale">Mention légal</a></li>
        {% if app.session.has('user_id') %}
        <li class="nav-menu-item"><a href="/deconnexion" style="color: #b00020; font-weight: bold;">Déconnexion</a></li>
        {% endif %}
    </ul>
</nav>

<div class="header-main-content">
    <!-- Header -->
    <header class="header">
        <div class="header-hamburger" onclick="toggleNav()">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <h1 class="title">LifePath</h1>
        <img  src="/images/logos/personnagesansfondombre.png" alt="logo lifePath" class="header-icon" >
    </header>
</div>

<main>
    <section style="padding: 40px 20px;">
        <h1>Mon Profil</h1>
        
        {% if app.session.has('user_id') %}
            <div style="margin-top: 30px; padding: 20px; border: 1px solid #ddd; border-radius: 8px;">
                {% if app.session.get('type') == 'particulier' %}
                    <h2>Informations Personnelles</h2>
                    <p><strong>Prénom :</strong> {{ app.session.get('prenom') }}</p>
                    <p><strong>Nom :</strong> {{ app.session.get('nom') }}</p>
                    <p><strong>Email :</strong> {{ app.session.get('email') }}</p>
                    <p><strong>Type :</strong> Particulier</p>
                {% else %}
                    <h2>Informations Entreprise</h2>
                    <p><strong>Société :</strong> {{ app.session.get('societe') }}</p>
                    <p><strong>Email :</strong> {{ app.session.get('email') }}</p>
                    <p><strong>Type :</strong> Entreprise</p>
                {% endif %}
            </div>
        {% else %}
            <div style="margin-top: 30px; padding: 20px; text-align: center;">
                <p>Vous n'êtes pas connecté.</p>
                <p><a href="/connexion" style="color: #0066cc; text-decoration: underline;">Se connecter</a></p>
            </div>
        {% endif %}
    </section>
</main>

<script src="/script.js"></script>
</body>

</html>
