<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>LifePath</title>
    <link rel="stylesheet" href="/assets/style_formulaire.css">
    <link rel="icon" type="image/png" href="/images/personnagesansfondombre.png">
</head>
<body>
<header class="Connect_subscribe">
    <img class="header_img" src="/images/logos/personnagesansfondombre.png" alt="Logo LifePath">
    <h1 class="tittle"><b>LifePath</b></h1>
    <h2 class="tittle2">Inscription</h2>
    <div class="toggle-container{% if form.mode == 'entreprise' %} entreprise{% endif %}" id="toggle">
        <div class="toggle-slider"></div>
        <div class="toggle-option">Particulier</div>
        <div class="toggle-option">Entreprise</div>
    </div>
</header>

<main>
    <section class="formulaire_inscription">
        {% if errors is not empty %}
            <article>
                <ul style="color:#b00020;">
                    {% for error in errors %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </article>
        {% endif %}

        {% if success_message %}
            <article>
                <p style="color:#0a7a31;">{{ success_message }}</p>
            </article>
        {% endif %}

        <article>
            <div class="container">

                <div id="form-particulier" class="form-section{% if form.mode != 'entreprise' %} active{% endif %}">

                    <form method="post" action="">
                        <input type="hidden" name="mode" value="particulier">

                        <div class="form-group" style="width:100%">
                            <label>Statut*</label>
                            <input class="btn_color" type="radio" id="statut-etudiant" name="statut" value="etudiant" required {% if form.statut == 'etudiant' %}checked{% endif %}> Etudiant
                            <input class="btn_color" type="radio" id="statut-pilote" name="statut" value="pilote" required {% if form.statut == 'pilote' %}checked{% endif %}> Pilote
                        </div>
                        <section class="deuxpardeux">
                            <div class="form-group">
                                <label>Nom*</label>
                                <input  type="text" name="nom" size="25" placeholder="Dupont" value="{{ form.nom|e }}" required>
                            </div>

                            <div class="form-group">
                                <label>Prenom*</label>
                                <input  type="text" name="prenom" size="25" placeholder="Titouan" value="{{ form.prenom|e }}" required>
                            </div>

                            <div class="form-group" id="groupe-classe">
                                <label>Classe*</label>
                                <input  type="text" id="classe" name="classe" size="25" placeholder="CPI-A2 Informatique" value="{{ form.classe|e }}" required>
                            </div>

                            <div class="form-group" id="groupe-pilote" {% if form.statut != 'etudiant' %}hidden{% endif %}>
                                <label for="pilote">Pilote</label>
                                <select id="pilote" name="pilot_id">
                                    <option value="">Selectionnez un pilote</option>
                                    {% for pilot in pilots %}
                                        <option value="{{ pilot.id_pilot }}" {% if form.pilot_id == (pilot.id_pilot ~ '') %}selected{% endif %}>{{ pilot.label }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="email">Email*</label>
                                <input  type="email" id="email" name="email" size="25" placeholder="turlututu@viacesi.fr" value="{{ form.email|e }}" required>
                            </div>

                            <div class="form-group">
                                <label>Mot de passe*</label>
                                <input  type="password" name="password" size="25" placeholder="********" required>
                            </div>

                            <div class="form-group">
                                <label>Confirmation</label>
                                <input  type="password" name="password_confirm" size="25" placeholder="********" required>
                            </div>
                        </section>

                        <div class="checkbox-container" style="width:100%">
                            <input class="btn_color" type="checkbox" name="accept_terms" required>
                            <label>J'accepte les <a href="legale">Conditions d'utilisation et la Politique de confidentialité</a></label>
                        </div>

                        <button class="submit" name="submit" type="submit">Inscription</button>
                    </form>
                    <p class="dejacompte">Deja un compte ? <a href="connexion" class="bouton_con">Connectez-vous</a></p>

                </div>

                <div id="form-entreprise" class="form-section{% if form.mode == 'entreprise' %} active{% endif %}">

                    <form method="post" action="">
                        <input type="hidden" name="mode" value="entreprise">

                        <div class="form-group">
                            <label for="societe">Nom de la societe*</label>
                            <input type="text" id="societe" name="societe" placeholder="Game Freak" value="{{ entreprise_form.societe|e }}" required>
                        </div>

                        <div class="form-group">
                            <label for="adresse">Adresse du siege social*</label>
                            <input type="text" id="adresse" name="adresse" placeholder="123 Rue de la Paix" value="{{ entreprise_form.adresse|e }}" required>
                        </div>

                        <div class="form-group">
                            <label for="email-pro">Email*</label>
                            <input type="email" id="email-pro" name="email-pro" placeholder="contact@gamefreak.fr" value="{{ entreprise_form['email-pro']|e }}" required>
                        </div>

                        <div class="form-group">
                            <label for="telephone-pro">Telephone*</label>
                            <input type="tel" id="telephone-pro" name="telephone-pro" placeholder="01 23 45 67 89" value="{{ entreprise_form['telephone-pro']|e }}" required>
                        </div>

                        <div class="form-group">
                            <label for="password-pro">Mot de passe*</label>
                            <input type="password" id="password-pro" name="password-pro" placeholder="********" required>
                        </div>

                        <div class="form-group">
                            <label for="password-pro-confirm">Confirmation*</label>
                            <input type="password" id="password-pro-confirm" name="password-pro-confirm" placeholder="********" required>
                        </div>

                        <button class="submit" name="submit-entreprise" type="submit">Inscription entreprise</button>
                    </form>
                </div>
            </div>
        </article>
    </section>
</main>

<script src="script_form.js?v=20260313"></script>
</body>
</html>
