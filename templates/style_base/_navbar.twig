<!-- Overlay -->
<div class="overlay" id="overlay"></div>

<!-- Navbar -->
<nav class="navbar" id="navbar">
    <div class="hamburger" onclick="toggleNav()">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div class="nav-profile-section">
        <img src="{{ profile.getPhoto()|default('/images/profils/profile.png') }}" alt="Photo de profil de {{ profile.prenom|default('l\'utilisateur') }}" class="offre-profile-img">
        <div class="nav-profile-info">
            {% if app.session.has('user_id') %}
                <h2>
                    {% if app.session.get('type') == 'etudiant' or app.session.get('type') == 'pilote' %}
                        <a href="/profil">{{ app.session.get('prenom') }} {{ app.session.get('nom') }}</a>
                    {% else %}
                        <a href="/profil">{{ app.session.get('societe') }}</a>
                    {% endif %}
                </h2>
                {% if app.session.get('type') == 'etudiant' %}
                    <p class="navbar-pilote">Étudiant</p>
                {% elseif app.session.get('type') == 'pilote' %}
                    <p class="navbar-pilote">Pilote</p>
                {% else %}
                    <p class="navbar-pilote">Entreprise</p>
                {% endif %}
            {% else %}
                <h2><a href="/profil">Utilisateur</a></h2>
                <p class="navbar-pilote">Non connecté</p>
            {% endif %}
        </div>
    </div>

    <div class="divider"></div>

    <ul class="nav-menu">
        <li class="nav-menu-item">
            <div class="row" onclick="toggleRow(this)">
                <div class="nav-container-menu">
                    <a href="/">Accueil </a>
                    <div class="arrow">></div>
                </div>
                <ul class="nav-submenu">
                    <li><a href="/#offres">Offres</a></li>
                    <li><a href="/#apropos">Entreprises</a></li>
                    <li><a href="/#compte">Comptes</a></li>
                </ul>
            </div>
        </li>
        {% if not app.session.has('user_id') %}
        <li class="nav-menu-item"><a href="/offres">Nos offres</a></li>
        <li class="nav-menu-item"><a href="/entreprise">Entreprise</a></li>
        <li class="nav-menu-item"><a href="/inscription">Inscription</a></li>
        <li class="nav-menu-item"><a href="/connexion">Connexion</a></li>
        {% endif %}
        {% if app.session.has('user_id') %}
            {% if app.session.get('type') == 'etudiant' %}
            <li class="nav-menu-item"><a href="/offres">Nos offres</a></li>
            <li class="nav-menu-item"><a href="/entreprise">Entreprise</a></li>
            {% elseif app.session.get('type') == 'pilote' %}
            <li class="nav-menu-item"><a href="/mes_etudiants">Mes étudiants</a></li>
            {% elseif app.session.get('type') == 'entreprise' %}
            <li class="nav-menu-item"><a href="/offres">Gérer mes offres</a></li>
            {% endif %}
        <li class="nav-menu-item"><a href="/avis">Avis</a></li>
        <li class="deconnexion"><a href="/deconnexion">Déconnexion</a></li>
        {% endif %}
    </ul>
</nav>