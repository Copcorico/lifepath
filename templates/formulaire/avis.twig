<!doctype html>
<html lang="fr">

<head>
	<meta charset="utf-8">
	<meta name="description" content="Partagez votre expérience sur LifePath. Déposez un avis et aidez-nous à améliorer nos services. Votre avis compte !">
	<meta name="keywords" content="lifepath, avis, témoignages, commentaires, évaluation, satisfaction client">
	<meta name="robots" content="index, follow">
	<link rel="canonical" href="https://www.lifepath.fr/avis.html">
	<link rel="stylesheet" href="assets/style.css">
	<!--<link rel="stylesheet" href="style_formulaire.css">-->
	<title>Avis Clients - Partagez votre Expérience LifePath</title>
</head>

<body>
{# Navbar #}
{% include 'style_base/header-navbar.twig' %}

	<section>

		<h1 class="center">Votre avis nous intéresse</h1>

		<p class="center">Vous avez une remarque à nous faire concernant nos services ou l'un des produits achetés
			via notre site ?</p>
		<p class="center">Utilisez simplement ce formulaire en nous fournissant le maximum d'informations afin de
			répondre au mieux à votre demande.</p>

		<article>

			<form class="formulaire">
				<h2>Description</h2>

				<label>Nom complet*<input name="fullname" type="text" value="" size="50" required></label>

				<label>Courriel*<input name="email" type="email" size="30" value="" required></label>

				<label>Objet de votre demande
					<select name="subject">
						<option>Produit acheté</option>
						<option>Service commercial</option>
						<option>Service technique</option>
						<option>Autres</option>
					</select>
				</label>



				<label>Catégorie.s concernée.s
					<div class="checkbox">
						<div class="box"><input type="checkbox" name="category" value="property">Immobilier</div>
						<div class="box"><input type="checkbox" name="category" value="cars">Véhicules</div>
						<div class="box"><input type="checkbox" name="category" value="clothes">Vêtements</div>
						<div class="box"><input type="checkbox" name="category" value="multimedia">Multimedia</div>
						<div class="box"><input type="checkbox" name="category" value="household">Maison</div>
						<div class="box"><input type="checkbox" name="category" value="hobbies">Loisirs</div>
						<div class="box"><input type="checkbox" name="category" value="services">Services</div>
					</div>
				</label>

				<label>
					Photo du produit défectueux
					<input type="file" id="file-upload" hidden>
					<label for="file-upload" class="upload-btn">Téléversement de fichier</label>
				</label>


				<label>Je suis satisfait
					<div class="checkbox">
						<div class="box"><input type="radio" name="satisfaction" value="yes" checked="checked">Oui
						</div>
						<div class="box"><input type="radio" name="satisfaction" value="no" checked="checked">Non
						</div>
					</div>

					<p class="small">En cas d'insatisfaction veuillez nous en fournir la raison.</p>
				</label>


				<label>Commentaires<textarea name="feedbacks" rows="5" cols="100"></textarea></label>

				<div class="buttons">
					<button type="submit">Envoyer</button>
					<input type="reset" value="Effacer">
				</div>
			</form>

		</article>

	</section>


	<footer class="footer">
		<em>2026 - Tous droits réservés</em> | <a href="mentions-legales.html">Mentions légales</a>
	</footer>
	<script src="script.js"></script>
</body>

</html>