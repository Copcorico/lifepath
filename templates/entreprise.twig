<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0">-->
    <title>Entreprise - LifePath</title>
    <link rel="stylesheet" href="assets/style.css">
    <link rel="icon" type="image/png" href="images/logos/personnagesansfondombre.png">
</head>

<body>
    <!-- Overlay -->
    <div class="overlay" id="overlay"></div>

    <!-- Navbar -->
    <nav class="navbar" id="navbar">
        <div class="hamburger" onclick="toggleNav()">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="profile-section">
            <div class="profile-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="8" r="4" fill="#1e3a5f"/>
                    <path d="M4 20c0-4 3.5-7 8-7s8 3 8 7" stroke="#1e3a5f" stroke-width="2" fill="none"/>
                </svg>
            </div>
            <div class="profile-info">
                <h2>NOM COMPLET</h2>
                <p>NOM pilote</p>
            </div>
        </div>

        <div class="divider"></div>

        <ul class="menu">
            <li class="menu-item active">
                <a href="index.html">
                    <div class="home-icon"></div>
                    Accueil
                    <span class="arrow">∨</span>
                </a>
                <ul class="submenu">
                    <li><a href="#offres">Offres</a></li>
                    <li><a href="#">Entreprises</a></li>
                    <li><a href="#">Comptes</a></li>
                </ul>
                <a href="inscription_entreprise.html">
                    Inscription
                </a>
                <a href="inscription_particulier.html">
                    Inscription
                </a>
                <a href="connexion.html">
                    Connexion
                </a>
                <a href="offres.html">
                    Nos offres
                </a>
                <a href="entreprise.html">
                    Entreprise
                </a>
                <a href="avis.html">
                    Avis
                </a>
                <a href="legale.html">
                    Mentions légales
                </a>
            </li>
        </ul>
    </nav>

    <div class="main-content">
        <!-- Header -->
        <header class="header">
            <div class="header-hamburger" onclick="toggleNav()">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <h1>LifePath</h1>
            <img src="images/logos/personnagesansfondombre.png" alt="logo lifePath" class="header-icon">
        </header>
    </div>

    <section class="entreprise-banner">
        <div class="coeur-card"></div>
        <img src="images/entreprise/entreprise.jpg" alt="Image de l'entreprise" class="entreprise-img">
    </section>

    <main>
        <article class="entreprise-container">
            <section class="entreprise-section">
                <h1>{{ company.nom }}</h1>
                <div class="star-rating">
                    {% for i in 1..5 %}
                        {% if i <= company.note %}⭐{% else %}☆{% endif %}
                    {% endfor %}
                    <span>({{ company.note }}/5)</span>
                </div>
            </section>
            <p class="entreprise-description">
                {{ company.description }}
            </p>
            <ul class="entreprise-info">
                <li>Taille : {{ company.nombre_employes }} salariés</li>
            </ul>

            <section class="offres-carousel" id="offres">
                <h2>Offres</h2>
                <div class="carousel">
                    {% set companyId = company.id_entreprise|default(0) %}
                    {% if prevPage %}
                        <a class="prev" href="?id={{ companyId }}&page={{ prevPage }}#offres" aria-label="Offre précédente">&lt;</a>
                    {% else %}
                        <span class="prev" aria-disabled="true">&lt;</span>
                    {% endif %}
                    <div class="carousel-track">
                        {% if currentOffre %}
                            <div class="offre-item">
                                <div class="offre-card">
                                    <img src="images/entreprise/entreprise.jpg" alt="{{ currentOffre.titre }}" class="offre-card-img">
                                    <div class="offre-card-info">
                                        <h3 class="offre-card-title">{{ currentOffre.titre }}</h3>
                                        <div class="offre-card-meta">
                                            {{ currentOffre.localisation|default('Non renseignee') }} • {{ currentOffre.niveau|default('Niveau non precise') }}
                                        </div>
                                        <p>{{ currentOffre.detail|default('Aucun detail disponible.') }}</p>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="offre-item">
                                <div class="offre-card">
                                    <div class="offre-card-info">
                                        <h3 class="offre-card-title">Aucune offre disponible</h3>
                                        <div class="offre-card-meta">Cette entreprise n'a pas encore publie d'offre.</div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    {% if nextPage %}
                        <a class="next" href="?id={{ companyId }}&page={{ nextPage }}#offres" aria-label="Offre suivante">&gt;</a>
                    {% else %}
                        <span class="next" aria-disabled="true">&gt;</span>
                    {% endif %}
                </div>
                <div class="carousel-dots">
                    {% if totalPages > 1 %}
                        {% for i in 1..totalPages %}
                            <a class="dot{% if i == page %} active{% endif %}" href="?id={{ companyId }}&page={{ i }}#offres" aria-label="Aller a l'offre {{ i }}"></a>
                        {% endfor %}
                    {% else %}
                        <span class="dot active"></span>
                    {% endif %}
                </div>
            </section>
        </article>
    </main>

    <footer>
        <p>&copy; 2026 Tous droits réservés</p>
        <a href="legale.html">Mentions légales et politique de confidentialité</a>
    </footer>


</body>
</html>
