<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0">-->
    <title>Offres - LifePath</title>
    <link rel="stylesheet" href="assets/style.css">
    <link rel="icon" type="image/png" href="images/logos/personnagesansfondombre.png">
</head>

<body>

    {% include 'style_base/_navbar.twig' %}
    {% include 'style_base/_header.twig' %}
    <main class="offer-detail">
        <article class="entreprise-container">
            <section class="entreprise-section">
                <h1>Recherche d'offres</h1>
                <p>Trouvez une offre et ouvrez sa page detail.</p>
            </section>

            <section id="entreprises">
                <form method="get" action="/offres" class="search-form">
                    <input
                        type="text"
                        name="q"
                        value="{{ query|default('') }}"
                        placeholder="Ex: Développement, Marketing, Communication..."
                        aria-label="Rechercher une offre par nom"
                        class="search-input"
                    >
                    <button type="submit" class="search-button">Rechercher</button>
                </form>
                                <button
                    type="button"
                    class="search-button btn-filters"
                    aria-expanded="false"
                    aria-controls="filters-panel"
                    onclick="(function(){const p=document.getElementById('filters-panel');const open=p.style.display==='block';p.style.display=open?'none':'block';this.setAttribute('aria-expanded', open ? 'false' : 'true');}).call(this)();"
                >
                    Filtres
                    <img src="/images/logos/filter.png" alt="logo filtres">
                </button>

                <section
                    id="filters-panel"
                    class="filters-panel"
                    style="display:{% if localisation is not empty or niveau is not null or salaire_min is not null or salaire_max is not null or duree is not null %}block{% else %}none{% endif %};"
                >
                    <form method="get" action="/offres" class="filter-form">
                        {% if query is not empty %}
                            <input type="hidden" name="q" value="{{ query }}">
                        {% endif %}

                        <label for="localisation">Localisation</label>
                        <input
                            id="localisation"
                            type="text"
                            name="localisation"
                            value="{{ localisation is not null ? localisation : '' }}"
                            placeholder="Ex: Paris, Lyon, Marseille..."
                            class="filter-input"
                        >

                        <label for="niveau">Année après le bac</label>
                        <input
                            id="niveau"
                            type="text"
                            name="niveau"
                            value="{{ niveau is not null ? niveau : '' }}"
                            placeholder="Ex: Bac+3, Bac +5, Master..."
                            class="filter-input"
                        >

                        <label for="salaire_min">Salaire minimal</label>
                        <input
                            id="salaire_min"
                            type="number"
                            name="salaire_min"
                            min="0"
                            max="100000"
                            step="100"
                            value="{{ salaire_min is not null ? salaire_min : '' }}"
                            placeholder="Ex: 20000"
                            class="filter-input"
                        >

                        <label for="salaire_max">Salaire maximale</label>
                        <input
                            id="salaire_max"
                            type="number"
                            name="salaire_max"
                            min="0"
                            max="100000"
                            step="100"
                            value="{{ salaire_max is not null ? salaire_max : '' }}"
                            placeholder="Ex: 40000"
                            class="filter-input"
                        >

                        <label for="duree">Durée</label>
                        <input
                            id="duree"
                            type="number"
                            name="duree"
                            min="0"
                            max="12"
                            step="1"
                            value="{{ duree is not null ? duree : '' }}"
                            placeholder="Ex: 3 mois, 6 mois..."
                            class="filter-input"
                        >

                        <div class="filter-actions">
                            <button type="submit" class="search-button">Appliquer</button>
                            <a href="/offres{% if query is not empty %}?q={{ query|url_encode }}{% endif %}" class="search-button btn-reset">Reinitialiser</a>
                        </div>
                    </form>
                </section>

                {% if query is not empty %}
                    <p><strong>{{ offers|length }}</strong> resultat(s) pour "{{ query }}".</p>
                {% endif %}

                <div class="companies-results" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 16px;">
                    {% for offer in offers %}
                        <a
                            href="/offres?id={{ offer.id_offre }}"
                            style="display:block; text-decoration:none; color:inherit;"
                            aria-label="Voir le detail de l'offre {{ offer.titre|default('sans titre') }}"
                        >
                            <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px; box-shadow:0 4px 14px rgba(0, 0, 0, 0.06); transition: transform .15s ease, box-shadow .15s ease;">
                                <h3 style="margin:0 0 8px 0;">{{ offer.titre|default('Offre sans titre') }}</h3>
                                <section class="entreprise-section">
                                    <div class="star-rating">
                                        {% for i in 1..5 %}
                                        {% if i <= offer.entreprise_note|default(0) %}★{% else %}☆{% endif %}
                                        {% endfor %}
                                    <span>({{ offer.entreprise_note|default(0) }}/5)</span>
                                    </div>
            </section>
                                <p style="margin:0 0 10px 0; color:#4b5563;">
                                    {{ offer.detail|default(offer['détail']|default('Aucune description disponible.')) }}
                                </p>
                                <div style="font-size: 14px; color:#374151;">
                                    <span><strong>Entreprise:</strong> {{ offer.entreprise_nom|default('Non renseignee') }}</span><br>
                                    <span><strong>Lieu:</strong> {{ offer.localisation|default('Non renseigne') }}</span><br>
                                    <span><strong>Niveau:</strong> {{ offer.niveau|default('Non renseigne') }}</span>
                                </div>
                            </article>
                        </a>
                    {% else %}
                        <article class="company-card" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px;">
                            <h3 style="margin:0 0 8px 0;">Aucune offre trouvee</h3>
                            <p style="margin:0; color:#4b5563;">Essayez un autre titre ou une recherche plus courte.</p>
                        </article>
                    {% endfor %}
                </div>
            </section>
        </article>
    </main>

    <footer>
        <p>&copy; 2026 Tous droits réservés</p>
        <a href="legale.html">Mentions légales et politique de confidentialité</a>
    </footer>


</body>
</html>
